{
  "redirects": [
    {
      "source": "/pages/iphone.html",
      "destination": "/index.html",
      "permanent": true
    },
    {
      "source": "/privacy-policy.html",
      "destination": "/privacy.html",
      "permanent": true
    },
    {
      "source": "/lofi",
      "destination": "/pages/lofi.html",
      "permanent": true
    },
    {
      "source": "/cyberpunk",
      "destination": "/pages/cyberpunk.html",
      "permanent": true
    },
    {
      "source": "/nature",
      "destination": "/pages/nature.html",
      "permanent": true
    },
    {
      "source": "/space",
      "destination": "/pages/space.html",
      "permanent": true
    },
    {
      "source": "/abstract",
      "destination": "/pages/abstract.html",
      "permanent": true
    },
    {
      "source": "/minimal",
      "destination": "/pages/minimal.html",
      "permanent": true
    },
    {
      "source": "/anime",
      "destination": "/pages/anime.html",
      "permanent": true
    },
    {
      "source": "/aesthetic",
      "destination": "/pages/aesthetic.html",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "www.wallrank.club"}],
      "destination": "https://wallrank.club/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{"key": "Content-Type", "value": "application/xml"}]
    },
    {
      "source": "/robots.txt",
      "headers": [{"key": "Content-Type", "value": "text/plain"}]
    }
  ]
}
