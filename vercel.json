{
  "redirects": [
    {
      "source": "/pages/iphone.html",
      "destination": "/index.html",
      "permanent": true
    },
    {
      "source": "/privacy-policy.html",
      "destination": "/privacy.html",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "www.wallrank.club"}],
      "destination": "https://wallrank.club/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{"key": "Content-Type", "value": "application/xml"}]
    },
    {
      "source": "/robots.txt",
      "headers": [{"key": "Content-Type", "value": "text/plain"}]
    }
  ]
}
